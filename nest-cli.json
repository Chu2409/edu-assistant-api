{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "assets": [
      {
        "include": "features/videos/ai/config/*.yaml",
        "watchAssets": true
      },
      {
        "include": "shared/templates/email/**/*",
        "watchAssets": true
      }
    ]
  }
}
