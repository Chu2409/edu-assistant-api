NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:4200
DB_URL=postgres://postgres:postgres@localhost:5440/edu_assistant

DB_PORT=5440
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=edu_assistant

# Microsoft OAuth Configuration
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_CALLBACK_URL=
MICROSOFT_TENANT=

# JWT Configuration
JWT_SECRET=
JWT_EXPIRATION=24h

REDIS_HOST=localhost
REDIS_PORT=6379

OPENAI_API_KEY=

# ============================================================
# Video AI Content Generation
# ============================================================
#
# VIDEO_AI_PROVIDER  - Which LLM provider to use for generating
#                      video content (summary, flashcards, quiz, glossary).
#                      Options: groq | openai | google | nvidia | ollama
#
# VIDEO_AI_MODEL     - The model ID to use with the selected provider.
#                      Must be a valid model for the chosen provider.
#
# Only the API key for your chosen provider is required.
# The rest can stay empty.
#
# -------------------------
# Provider quick reference:
# -------------------------
#
# groq (default, free tier available):
#   VIDEO_AI_PROVIDER=groq
#   VIDEO_AI_MODEL=llama-3.3-70b-versatile
#   GROQ_API_KEY=gsk_...
#
# openai:
#   VIDEO_AI_PROVIDER=openai
#   VIDEO_AI_MODEL=gpt-4o-mini
#   OPENAI_API_KEY=sk-...
#
# google (Gemini):
#   VIDEO_AI_PROVIDER=google
#   VIDEO_AI_MODEL=gemini-2.0-flash
#   GOOGLE_GENERATIVE_AI_API_KEY=AIza...
#
# nvidia (OpenAI-compatible API):
#   VIDEO_AI_PROVIDER=nvidia
#   VIDEO_AI_MODEL=meta/llama-3.3-70b-instruct
#   NVIDIA_API_KEY=nvapi-...
#   NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1  (default)
#
# ollama (local, no API key needed):
#   VIDEO_AI_PROVIDER=ollama
#   VIDEO_AI_MODEL=llama3
#   OLLAMA_BASE_URL=http://localhost:11434  (default)
#
# ============================================================

VIDEO_AI_PROVIDER=groq
VIDEO_AI_MODEL=llama-3.3-70b-versatile
VIDEO_AI_REQUEST_TIMEOUT=120000

# Provider API keys (only fill the one you're using)
GROQ_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
# Toggle reasoning/thinking for NVIDIA reasoning models (z-ai/glm, stepfun, etc.).
# Set to 'true' to keep the model's reasoning_content output (uses more tokens).
# Default 'false' — disables thinking for faster, cheaper, shorter responses.
NVIDIA_ENABLE_THINKING=false
OLLAMA_BASE_URL=http://localhost:11434

# Whisper (local transcription for uploaded video files)
WHISPER_MODEL=base
WHISPER_LANGUAGE=auto
WHISPER_MODELS_DIR=/models
WHISPER_MODELS_HOST_DIR=/home/dide/docker/edu-assistant-test/whisper-models

MAX_VIDEO_DURATION_MINUTES=30
MAX_VIDEO_FILE_SIZE_MB=500
